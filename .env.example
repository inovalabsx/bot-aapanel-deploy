# Bot aapanel-deploy — Config
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env real!

# Token do bot Telegram (de @BotFather)
BOT_TOKEN=SEU_TOKEN_AQUI

# IDs dos usuários que podem usar o bot (separados por vírgula)
# Deixe vazio para permitir todos
ALLOWED_USERS=SEU_TELEGRAM_ID

# Diretório para dados do bot (configurações por usuário)
BOT_DATA_DIR=/root/.aapanel-deploy
